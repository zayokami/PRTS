{
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "${WORKSPACE_DIR}"
      ],
      "disabled": true
    },
    "prts-vector": {
      "command": "prts-vector",
      "args": [
        "--db",
        "${WORKSPACE_DIR}/vector.db",
        "--dim",
        "1536"
      ],
      "disabled": true
    },
    "prts-workspace": {
      "command": "prts-workspace",
      "env": {
        "PRTS_WORKSPACE_DIR": "${WORKSPACE_DIR}"
      },
      "disabled": true
    }
  }
}
