# ===== LLM 后端选择 =====
# openai = 走 OpenAI 协议(任意 base_url:OpenAI/DeepSeek/Qwen/Ollama/...)
# anthropic = 走 native anthropic SDK(保留 prompt caching / extended thinking)
LLM_PROVIDER=openai

# --- OpenAI 协议(LLM_PROVIDER=openai 时生效)---
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=sk-...

# DeepSeek 示例
# LLM_BASE_URL=https://api.deepseek.com
# LLM_MODEL=deepseek-chat
# LLM_API_KEY=sk-...

# Ollama 本地示例
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=qwen2.5:14b
# LLM_API_KEY=ollama

# --- Anthropic native(LLM_PROVIDER=anthropic 时生效)---
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# ===== 进程端口 =====
# 8787/8788 在 Windows 默认排除段(8751-8850),用 4787/4788 避坑
DASHBOARD_PORT=5173
GATEWAY_PORT=4787
AGENT_PORT=4788

# ===== 路径 =====
# 默认 ~/.prts/workspace,首次启动从 ./workspace 模板初始化
PRTS_WORKSPACE_DIR=
# SQLite 文件
PRTS_DB_PATH=./db/prts.db

# ===== Telegram(P5 阶段)=====
TELEGRAM_BOT_TOKEN=
# polling(默认,开发用) | webhook(生产,需公网 HTTPS)
BOT_MODE=polling
